{
  "expo": {
    "name": "ThreatTrack Mobile",
    "slug": "threattrack-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/favicon.png",
    "splash": {
      "image": "./assets/favicon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a2d52"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.threattrack.mobile"
    },
    "android": {
      "package": "com.threattrack.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/favicon.png",
        "backgroundColor": "#1a2d52"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
