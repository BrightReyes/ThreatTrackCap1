{
  "expo": {
    "name": "ThreatTrack Login",
    "slug": "threattrack-login",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./mobile/assets/favicon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./mobile/assets/favicon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./mobile/assets/favicon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.anonymous.threattracklogin"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
