rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === HELPER FUNCTIONS ===
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function callerUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function callerRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? callerUserDoc().data.role
        : null;
    }

    function isAdmin() {
      return isAuthenticated() &&
             callerRole() in ['admin', 'moderator'];
    }

    // Staff (admin, moderator, police): can edit other users' Firestore profiles (not Auth).
    function canManageUserProfiles() {
      return isAuthenticated() &&
             callerRole() in ['admin', 'moderator', 'police'];
    }

    function isValidIncident() {
      let data = request.resource.data;
      return data.keys().hasAll(['type', 'severity', 'location', 'description', 'timestamp']) &&
             data.type in ['theft', 'assault', 'vandalism', 'robbery', 'burglary', 'other'] &&
             data.severity in ['high', 'medium', 'low'] &&
             data.description is string &&
             data.description.size() >= 10 &&
             data.description.size() <= 2000 &&
             data.location.latitude is number &&
             data.location.longitude is number &&
             data.location.latitude >= -90 &&
             data.location.latitude <= 90 &&
             data.location.longitude >= -180 &&
             data.location.longitude <= 180;
    }

    function hasNotExceededRateLimit() {
      // Simplified; production should enforce via Cloud Functions or server
      return true;
    }

    // === USERS COLLECTION ===
    match /users/{userId} {
      // Anyone authenticated can read user profiles
      allow read: if isAuthenticated();

      // Users can only create their own profile
      allow create: if isOwner(userId) &&
                    request.resource.data.uid == userId &&
                    request.resource.data.email == request.auth.token.email;

      // Users update own profile (email unchanged). Staff may update others: uid must match doc id,
      // and only safe scalar fields may change (diff-based — avoids email== failures when email is missing/mismatched).
      allow update: if (isOwner(userId) &&
                    request.resource.data.uid == userId &&
                    request.resource.data.email == resource.data.email) ||
                   (canManageUserProfiles() &&
                    request.resource.data.uid == userId &&
                    request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['firstName', 'lastName', 'role', 'uid']));

      // Users can delete their own profile, admins can delete any
      allow delete: if isOwner(userId) || isAdmin();
    }

    // === INCIDENTS COLLECTION ===
    match /incidents/{incidentId} {
      // Allow public reads so the app can fetch incidents for display
      allow read: if true;

      // Authenticated users can create incidents with valid data
      // Allow creation when the authenticated user is the reporter.
      // Relaxed checks: accept status values set by client/server and require reporterId match.
      allow create: if (isAdmin()) ||
            (isAuthenticated() &&
              isValidIncident() &&
              hasNotExceededRateLimit() &&
              request.resource.data.reporterId == request.auth.uid);

      // Users can update their own pending incidents
      allow update: if isOwner(resource.data.reporterId) &&
                    resource.data.status == 'pending' &&
                    isValidIncident();

      // Admins can update or delete any incident (for moderation)
      allow update, delete: if isAdmin();

      // Users can delete their own pending incidents
      allow delete: if isOwner(resource.data.reporterId) && resource.data.status == 'pending';
    }

    // === INCIDENTS ARCHIVE COLLECTION ===
    match /incidents_archive/{incidentId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // === PRECINCTS COLLECTION ===
    match /precincts/{precinctId} {
      // Precincts are public safety info — public read
      allow read: if true;

      // Only admins can create, update, or delete precincts
      allow write: if isAdmin();
    }

    // === CRIME STATISTICS COLLECTION ===
    match /crime_statistics/{statisticId} {
      // Authenticated users can read aggregated statistics
      allow read: if isAuthenticated();

      // Only server/Cloud Functions should write
      allow write: if false;
    }

    // === NOTIFICATIONS COLLECTION ===
    match /notifications/{notificationId} {
      // Users can read their own notifications; admins/moderators can read all for the dashboard
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());

      // Users can mark their own notifications as read. Admins/moderators can moderate notifications in dashboard.
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAdmin();
      allow create: if false;
    }

    // === SETTINGS COLLECTION ===
    // Stores admin-controlled system configuration (read-only for non-admins).
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // === AUDIT LOGS COLLECTION ===
    // Client-side audit trail for admin panel actions.
    // Note: for tamper-proof audit trails, write via server/Cloud Functions instead.
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Fallback: deny by default (explicit rules above control access)
  }
}

