rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === HELPER FUNCTIONS ===
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function callerUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function callerRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? callerUserDoc().data.role
        : null;
    }

    function isAdmin() {
      return isAuthenticated() &&
             callerRole() in ['admin', 'moderator'];
    }

    function isPoliceAdmin() {
      return isAuthenticated() &&
             callerRole() == 'police';
    }

    // Staff (admin, moderator, police): can edit other users' Firestore profiles (not Auth).
    function canManageUserProfiles() {
      return isAuthenticated() &&
             callerRole() in ['admin', 'moderator', 'police'];
    }

    function isPoliceOperationalIncident() {
      let data = request.resource.data;
      return isPoliceAdmin() &&
             isValidIncident() &&
             data.source == 'police_admin' &&
             data.createdFrom == 'admin_operation' &&
             data.isAdminGenerated == true &&
             data.createdBy == request.auth.uid &&
             data.reportingAs == 'police_station' &&
             data.status in ['under_review', 'verified'] &&
             ((data.severity == 'high' &&
               data.priority == 'high' &&
               data.notificationAudience == 'active_app_users') ||
              (data.severity in ['medium', 'low'] &&
               data.priority == 'normal' &&
               data.notificationAudience == 'none'));
    }

    function isPoliceUrgentNotification() {
      let data = request.resource.data;
      return isPoliceAdmin() &&
             data.type == 'police_urgent_report' &&
             data.severity == 'high' &&
             data.priority == 'high' &&
             data.source == 'police_admin' &&
             data.createdBy == request.auth.uid &&
             data.userId is string &&
             data.incidentId is string &&
             data.title is string &&
             data.body is string;
    }

    function isValidIncident() {
      let data = request.resource.data;
      return data.keys().hasAll(['type', 'severity', 'location', 'description', 'timestamp']) &&
             data.type in [
               'theft_snatching',
               'robbery_holdup',
               'physical_assault_injury',
               'domestic_violence',
               'drug_related_activity',
               'public_disturbance',
               'vandalism_property_damage',
               'traffic_accident',
               'illegal_weapons',
               'suspicious_activity'
             ] &&
             data.severity in ['high', 'medium', 'low'] &&
             data.description is string &&
             data.description.size() >= 10 &&
             data.description.size() <= 2000 &&
             data.location.latitude is number &&
             data.location.longitude is number &&
             data.location.latitude >= -90 &&
             data.location.latitude <= 90 &&
             data.location.longitude >= -180 &&
             data.location.longitude <= 180;
    }

    function isValidIncidentPhotoUpdate() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return isOwner(resource.data.reporterId) &&
             request.resource.data.reporterId == resource.data.reporterId &&
             request.resource.data.status == resource.data.status &&
             isValidIncident() &&
             changedKeys.hasOnly(['photoURL']) &&
             request.resource.data.photoURL is string &&
             request.resource.data.photoURL.size() > 0;
    }

    function hasNotExceededRateLimit() {
      // Simplified; production should enforce via Cloud Functions or server
      return true;
    }

    // === USERS COLLECTION ===
    match /users/{userId} {
      // Anyone authenticated can read user profiles
      allow read: if isAuthenticated();

      // Users can create their own profile; staff can create profiles from dashboard.
      allow create: if (isOwner(userId) &&
                    request.resource.data.uid == userId &&
                    request.resource.data.email == request.auth.token.email) ||
                   (canManageUserProfiles() &&
                    request.resource.data.uid == userId &&
                    request.resource.data.email is string &&
                    request.resource.data.role in ['user', 'police', 'admin', 'moderator'] &&
                    request.resource.data.status in ['active', 'inactive', 'suspended']);

      // Users update own profile (email unchanged). Staff may update others: uid must match doc id,
      // and only safe scalar fields may change (diff-based — avoids email== failures when email is missing/mismatched).
      allow update: if (isOwner(userId) &&
                    request.resource.data.uid == userId &&
                    request.resource.data.email == resource.data.email) ||
                   (canManageUserProfiles() &&
                    request.resource.data.uid == userId &&
                    request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['firstName', 'lastName', 'role', 'status', 'disabled', 'suspended', 'uid']));

      // Users can delete their own profile; staff can delete dashboard-managed profiles.
      allow delete: if isOwner(userId) || canManageUserProfiles();
    }

    // === INCIDENTS COLLECTION ===
    match /incidents/{incidentId} {
      // Allow public reads so the app can fetch incidents for display
      allow read: if true;

      // Authenticated users can create incidents with valid data
      // Allow creation when the authenticated user is the reporter.
      // Relaxed checks: accept status values set by client/server and require reporterId match.
      allow create: if (isAdmin() || isPoliceAdmin() || isPoliceOperationalIncident()) ||
            (isAuthenticated() &&
              isValidIncident() &&
              hasNotExceededRateLimit() &&
              request.resource.data.reporterId == request.auth.uid);

      // Users can update their own pending incidents
      allow update: if isOwner(resource.data.reporterId) &&
                    resource.data.status == 'pending' &&
                    request.resource.data.reporterId == resource.data.reporterId &&
                    isValidIncident();

      // Users can attach the uploaded evidence photo URL to their own incident
      // after creation, even if validation has already moved it out of pending.
      allow update: if isValidIncidentPhotoUpdate();

      // Barangay/Police admins can update or delete incidents for moderation and data tools.
      allow update, delete: if isAdmin() || isPoliceAdmin();

      // Users can delete their own pending incidents
      allow delete: if isOwner(resource.data.reporterId) && resource.data.status == 'pending';
    }

    // === INCIDENTS ARCHIVE COLLECTION ===
    match /incidents_archive/{incidentId} {
      allow read: if isAdmin() || isPoliceAdmin();
      allow write: if isAdmin() || isPoliceAdmin();
    }

    // === PRECINCTS COLLECTION ===
    // Precincts are public safety information - always readable
    match /precincts/{precinctId} {
      allow read, list: if true;
      allow create, update, delete: if isAdmin() || isPoliceAdmin();
    }

    // === CRIME STATISTICS COLLECTION ===
    match /crime_statistics/{statisticId} {
      // Authenticated users can read aggregated statistics
      allow read: if isAuthenticated();

      // Only server/Cloud Functions should write
      allow write: if false;
    }

    // === NOTIFICATIONS COLLECTION ===
    match /notifications/{notificationId} {
      // Users can read their own notifications; Barangay/Police admins can read all for the dashboard
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin() || isPoliceAdmin());

      // Users can mark their own notifications as read. Barangay/Police admins can moderate notifications in dashboard.
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin() || isPoliceAdmin());
      allow delete: if isAdmin() || isPoliceAdmin();
      allow create: if isAdmin() || isPoliceUrgentNotification();
    }

    // === SETTINGS COLLECTION ===
    // Stores admin-controlled system configuration.
    // Barangay and police admins can manage settings.
    match /settings/{settingId} {
      allow read: if isAdmin() || isPoliceAdmin();
      allow write: if isAdmin() || isPoliceAdmin();
    }

    // === AUDIT LOGS COLLECTION ===
    // Client-side audit trail for admin panel actions.
    // Note: for tamper-proof audit trails, write via server/Cloud Functions instead.
    match /audit_logs/{logId} {
      allow read: if isAdmin() || isPoliceAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // Fallback: deny by default (explicit rules above control access)
  }
}

