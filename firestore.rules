rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === HELPER FUNCTIONS ===
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'moderator'];
    }

    function isValidIncident() {
      let data = request.resource.data;
      return data.keys().hasAll(['type', 'severity', 'location', 'description', 'timestamp']) &&
             data.type in [
               'theft_snatching',
               'robbery_holdup',
               'physical_assault_injury',
               'domestic_violence',
               'drug_related_activity',
               'public_disturbance',
               'vandalism_property_damage',
               'traffic_accident',
               'illegal_weapons',
               'suspicious_activity'
             ] &&
             data.severity in ['high', 'medium', 'low'] &&
             data.description is string &&
             data.description.size() >= 10 &&
             data.description.size() <= 2000 &&
             data.location.latitude is number &&
             data.location.longitude is number &&
             data.location.latitude >= -90 &&
             data.location.latitude <= 90 &&
             data.location.longitude >= -180 &&
             data.location.longitude <= 180;
    }

    function hasNotExceededRateLimit() {
      // Simplified; production should enforce via Cloud Functions or server
      return true;
    }

    // === USERS COLLECTION ===
    match /users/{userId} {
      // Anyone authenticated can read user profiles
      allow read: if isAuthenticated();

      // Users can only create their own profile
      allow create: if isOwner(userId) &&
                    request.resource.data.uid == userId &&
                    request.resource.data.email == request.auth.token.email;

      // Users can only update their own profile
      allow update: if isOwner(userId) &&
                    request.resource.data.uid == userId &&
                    request.resource.data.email == resource.data.email; // Email can't be changed here

      // Users can delete their own profile, admins can delete any
      allow delete: if isOwner(userId) || isAdmin();
    }

    // === INCIDENTS COLLECTION ===
    match /incidents/{incidentId} {
      // Allow public reads so the app can fetch incidents for display
      allow read: if true;

      // Authenticated users can create incidents. Require authenticated reporterId match.
      // NOTE: Temporarily relax shape validation to avoid permission failures from serverTimestamp
      // during client writes. We keep rate limit placeholder.
      allow create: if isAuthenticated() &&
              hasNotExceededRateLimit() &&
              request.resource.data.reporterId == request.auth.uid;

      // Users can update their own pending incidents
      allow update: if isOwner(resource.data.reporterId) &&
                    resource.data.status == 'pending' &&
                    isValidIncident();

      // Admins can update or delete any incident (for moderation)
      allow update, delete: if isAdmin();

      // Users can delete their own pending incidents
      allow delete: if isOwner(resource.data.reporterId) && resource.data.status == 'pending';
    }

    // === PRECINCTS COLLECTION ===
    // Precincts are public safety information - always readable
    match /precincts/{precinctId} {
      allow read, list: if true;
      allow create, update, delete: if isAdmin();
    }

    // === CRIME STATISTICS COLLECTION ===
    match /crime_statistics/{statisticId} {
      // Authenticated users can read aggregated statistics
      allow read: if isAuthenticated();

      // Only server/Cloud Functions should write
      allow write: if false;
    }

    // === NOTIFICATIONS COLLECTION ===
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;

      // Users cannot write notifications directly
      allow write: if false;
    }

    // Fallback: deny by default (explicit rules above control access)
  }
}

